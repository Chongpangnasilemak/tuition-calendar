rules_version = '2';

// =============================================================================
// Private Tutor Scheduling App — Firestore Security Rules (FINAL, hardened)
//
// SINGLE TRUST ANCHOR
//   - Tutor identity      == existence of /admins/{uid}  (console-created, never client-writable).
//   - Parent->child link  == caller's own /users/{uid}.studentIds (console-provisioned,
//                            never client-writable). This is the ONLY authority for
//                            "is this my child". No denormalized parentUids on any content
//                            doc is ever trusted for authz.
//
// PUBLIC LAYER carries NO identity and NO persistent per-student id:
//   /bookings holds time/status only; studentId is hard-banned so the anonymous
//   busy-blocks stay unlinkable. Detail lives in /lessons/{bookingId} (same id, 1:1),
//   gated per-document by isParentOf(resource.data.studentId).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid()        { return request.auth.uid; }

    function isTutor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(uid()));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function userExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(uid()));
    }

    // SINGLE authority for the parent<->child link: caller's own /users doc.
    // Never trusts a denormalized array on a content document.
    function isParentOf(studentId) {
      return userExists()
        && userData().role == 'parent'
        && studentId in userData().studentIds;
    }

    // ---- admins: existence == tutor. Never client-writable. ----
    match /admins/{adminUid} {
      allow read:  if isSignedIn() && uid() == adminUid;
      allow write: if false;
    }

    // ---- users: console/server provisioned only. Trust anchor. ----
    match /users/{userUid} {
      allow read:  if isSignedIn() && (uid() == userUid || isTutor());
      allow write: if false;
    }

    // ---- students: PRIVATE (carries name). parentUids on the doc is a query
    //      convenience ONLY and is never used for authz. ----
    match /students/{studentId} {
      allow read:  if isTutor() || isParentOf(studentId);
      allow write: if isTutor();
    }

    // ---- bookings: PUBLIC-to-authed. Time/status ONLY. NO identity, NO
    //      studentId. The validator hard-bans every identifying/linking key so
    //      a careless future write cannot reintroduce a correlation key.
    //      create is allowed for the tutor OR a parent (self-booking an open
    //      slot) — the identity ban keeps it anonymous either way; update/delete
    //      stay tutor-only. ----
    match /bookings/{bookingId} {
      allow read: if isSignedIn();

      allow create: if (isTutor() || (userExists() && userData().role == 'parent'))
        && !request.resource.data.keys().hasAny(
             ['studentId', 'studentName', 'subject', 'notes',
              'parentUid', 'parentUids', 'name', 'seriesId']
           );

      allow update: if isTutor()
        && !request.resource.data.keys().hasAny(
             ['studentId', 'studentName', 'subject', 'notes',
              'parentUid', 'parentUids', 'name', 'seriesId']
           );

      allow delete: if isTutor();
    }

    // ---- lessons: PRIVATE detail, 1:1 with bookings by doc id.
    //      Authority = isParentOf(resource.data.studentId). Client MUST query
    //      with where('studentId','in', myStudentIds) (rules are not filters).
    //      create: tutor (any real student), OR a parent for their OWN child
    //      (self-booking). update/delete stay tutor-only so a parent can't edit
    //      a lesson after it's booked. ----
    match /lessons/{lessonId} {
      allow read: if isTutor() || isParentOf(resource.data.studentId);

      // NOTE: a parent-created lesson is only ever for their OWN child, and the
      // app only does this inside the open-slot booking transaction. Rules can't
      // cheaply prove "ties to a claimed slot", but the blast radius is tiny:
      // worst case a linked parent adds a lesson for their own child, which the
      // tutor sees and can cancel. Acceptable for a solo tutor.
      allow create: if exists(/databases/$(database)/documents/students/$(request.resource.data.studentId))
        && (isTutor() || isParentOf(request.resource.data.studentId));

      allow update: if isTutor()
        && exists(/databases/$(database)/documents/students/$(request.resource.data.studentId));

      allow delete: if isTutor();
    }

    // ---- settings: tutor-managed app settings (e.g. payment/PayNow id).
    //      Readable by any signed-in user (parents need the PayNow id to make a
    //      QR); writable by the tutor only. No sensitive data here. ----
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isTutor();
    }

    // ---- openslots: tutor-published bookable slots (time/status only, no
    //      identity). Any signed-in user may read; only the tutor creates/deletes.
    //      A parent may UPDATE only to claim an open slot (status -> 'taken');
    //      they may not change the time. The booking+lesson are created in the
    //      same client transaction (allowed by the bookings/lessons rules above).
    match /openslots/{slotId} {
      allow read: if isSignedIn();
      allow create, delete: if isTutor();
      allow update: if isTutor()
        || (userExists() && userData().role == 'parent'
            && resource.data.status == 'open'
            && request.resource.data.status == 'taken'
            && request.resource.data.start == resource.data.start
            && request.resource.data.end == resource.data.end);
    }

    // ---- requests: AUTHOR-only read (no co-parent leakage of free-text note).
    //      reschedule -> bookingId is string; additional -> no bookingId.
    //      Ownership of the target booking is re-verified by the tutor at
    //      approval time (lessons/{bookingId}.studentId == request.studentId). ----
    match /requests/{requestId} {

      // A parent reads their OWN requests. Filtering by parentUid == uid() is
      // sufficient authority (the create rule already guaranteed the request was
      // for this parent's own child). We intentionally do NOT also require
      // isParentOf(studentId) here: rules are not filters, so a list query
      // constrained only by parentUid must be provably safe on parentUid alone —
      // adding the studentId check would reject the whole query.
      allow read: if isTutor()
        || (isSignedIn() && resource.data.parentUid == uid());

      allow create: if isParentOf(request.resource.data.studentId)
        && request.resource.data.parentUid == uid()
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['reschedule', 'additional']
        && (
             (request.resource.data.type == 'reschedule'
                && request.resource.data.bookingId is string)
             ||
             (request.resource.data.type == 'additional'
                && !('bookingId' in request.resource.data.keys()))
           )
        && request.resource.data.proposedStart is timestamp
        && request.resource.data.proposedEnd  is timestamp
        && request.resource.data.proposedStart < request.resource.data.proposedEnd
        // no co-parent fan-out: a request may not smuggle a parentUids array.
        && !request.resource.data.keys().hasAny(['parentUids']);

      // Tutor resolves; may not rewrite who/what the request is about.
      allow update: if isTutor()
        && request.resource.data.parentUid == resource.data.parentUid
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.type      == resource.data.type
        && request.resource.data.status in ['pending', 'approved', 'declined'];

      // Author may withdraw own pending request; tutor may delete any.
      allow delete: if isTutor()
        || (isSignedIn()
            && resource.data.parentUid == uid()
            && resource.data.status == 'pending');
    }

    // ---- invites: link a parent account to a student.
    //      ONLY the tutor reads/writes invites from the client. A parent must
    //      NOT read invites (they pair student names with parent emails) and
    //      must NOT write the link itself. Redemption is performed by the
    //      `redeemInvite` Cloud Function (Admin SDK), which validates the code,
    //      enforces single-use, and is the only thing that writes
    //      users/{uid}.studentIds. The Admin SDK bypasses these rules, so no
    //      client read/write path to invites is needed for parents. ----
    match /invites/{code} {
      allow read, write: if isTutor();
      // parents: no client access (the Cloud Function handles redemption)
    }

    // -------------------------- Default deny ---------------------------------
    match /{document=**} { allow read, write: if false; }
  }
}
